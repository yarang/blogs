[Unit]
Description=Auto Comment Worker for Blog
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/var/www/auto-comment-worker
Environment="PORT=8081"
LoadCredential=github_token:.github-token
Environment="GITHUB_TOKEN_FILE=${CREDENTIALS_DIRECTORY}/github_token"
Environment="CLAUDE_CODE_PATH=/home/ubuntu/.local/bin/claude"
Environment="BLOG_OWNERS=yarang"
Environment="GITHUB_WEBHOOK_SECRET_FILE=${CREDENTIALS_DIRECTORY}/webhook_secret"
ExecStart=/usr/bin/python3 /var/www/auto-comment-worker/auto-comment-worker.py
Restart=always
RestartSec=10

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=auto-comment-worker

# Security
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/var/www/auto-comment-worker
ReadOnlyPaths=/etc/auto-comment-worker

# 리소스 제한
MemoryMax=512M
CPUQuota=50%
TasksMax=100

[Install]
WantedBy=multi-user.target
